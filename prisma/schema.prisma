generator client {
provider = "prisma-client-js"
}

datasource db {
provider = "postgresql"
url      = env("DATABASE_URL")
}

model SoulScan {
id         String   @id @default(cuid())
input      String
archetype  String
emotion    String
insight    String
createdAt  DateTime @default(now())
}

model DreamAnalysis {
id             String   @id @default(cuid())
dream          String
summary        String
emotion        String
interpretation String
createdAt      DateTime @default(now())
}

model TarotReading {
id         String   @id @default(cuid())
card       String
meaning    String
guidance   String
createdAt  DateTime @default(now())
}

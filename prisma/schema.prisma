prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SoulScan {
  id         String   @id @default(cuid())
  userId     String
  input      String
  archetype  String
  emotion    String
  insight    String
  createdAt  DateTime @default(now())
}

model DreamAnalysis {
  id             String   @id @default(cuid())
  userId         String
  dream          String
  summary        String
  emotion        String
  interpretation String
  createdAt      DateTime @default(now())
}

model TarotReading {
  id         String   @id @default(cuid())
  userId     String
  card       String
  meaning    String
  guidance   String
  createdAt  DateTime @default(now())
}

model UserUsage {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime

  soulScan  Int      @default(0)
  dream     Int      @default(0)
  tarot     Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  plan      String   @default("free") // free | pro
  createdAt DateTime @default(now())
}
